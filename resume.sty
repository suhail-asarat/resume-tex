% #1: Position, #2: Date, #3: Event/Group, #4: Organization, #5: Bullet Points
\newcommand{\resumeExtracurricularActivity}[5]{
    \begin{twocolentry}{\textit{#2}}
        \textbf{#1}
    \end{twocolentry}
    \begin{twocolentry}{\textit{#4}}
