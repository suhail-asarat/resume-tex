% #1: Cert Name, #2: Issuer, #3: Date, #4: Link Text, #5: Link URL
\newcommand{\resumeCert}[5]{
    \begin{twocolentry}{\textit{Issued #3}}
        \textbf{#1}
    \end{twocolentry}
    \begin{twocolentry}{\textit{\href{#5}{#4}}}
        \textit{#2}
    \end{twocolentry}
    \vspace{0.2 cm}
}
